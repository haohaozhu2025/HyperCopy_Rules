{
  "id": "cloud_link_com.coolapk.market",
  "name": "酷安",
  "category": "link",
  "enabled": true,
  "actionMode": "direct_open",
  "matchRegex": "https?://(?:www\\.)?coolapk\\.com/.+",
  "parameterRegex": "https?://(.+)",
  "triggerRegexes": [
    "https?://(?:www\\.)?coolapk\\.com/.+"
  ],
  "extractionRegexes": [
    "https?://(.+)"
  ],
  "parseAfterRedirect": false,
  "clearClipboardAfterJump": true,
  "target": {
    "type": "intent",
    "template": "intent://${raw:r1}#Intent;scheme=coolmarket;package=com.coolapk.market;end",
    "packageName": "com.coolapk.market",
    "action": "android.intent.action.VIEW"
  }
}