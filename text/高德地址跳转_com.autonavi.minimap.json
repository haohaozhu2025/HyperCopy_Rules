{
  "id": "androidamap_adress",
  "name": "高德地图地址跳转",
  "category": "address",
  "enabled": true,
  "actionMode": "direct_open",
  "matchRegex": "(?=.*(地址|省|市|镇)).{10,}",
  "parameterRegex": "(.+)",
  "target": {
    "type": "url",
    "template": "androidamap:\/\/poi?keywords=${input}",
    "packageName": "com.autonavi.minimap",
    "action": "android.intent.action.VIEW"
  },
  "sourceUrl": "",
  "createdAt": 1782825816808
}